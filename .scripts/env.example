# Copy to .scripts/.env and fill in the values you need.
# Loaded by .scripts/build.sh and .scripts/run_tests.sh

# Override python3 binary if not on PATH
#PYTHON3_BIN=/usr/local/bin/python3

# Override the StyLua binary cache dir (default ~/.cache/bins).
# StyLua is auto-fetched by .scripts/stylua.sh
#STYLUA_CACHE=/path/to/cache

# Required for build.sh --publish. Get token from ESOUI
#ESOUI_API_TOKEN=

# Test runner paths (run_tests.sh)
# If not set, it will try to download tools next to repo
# use specific src paths (run_tests.sh does NOT append subdirs to them)
#ESOLUA=../esolua/src/lua
#ESOUI_SRC=../esoui/esoui
#TANETH_DIR=../ESO-Taneth/src
